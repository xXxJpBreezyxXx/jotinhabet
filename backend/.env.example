# Server Configuration
PORT=4000
NODE_ENV=development

# Supabase Database Configuration
# Use the direct postgres connection URI or the REST API credentials
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
# Conexão direta ao Postgres (usada pelas migrations em src/db/migrate.ts)
DATABASE_URL=postgresql://postgres:your-db-password@your-supabase-host:5432/postgres

# Security
# 32-byte encryption key (hex or base64) for Fernet/AES symmetric encryption of credentials
# Example generation command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# Notification API - Evolution API (WhatsApp)
EVOLUTION_API_URL=https://your-evolution-host/
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=your-instance-name
# Destino dos alertas. Aceita:
#  - número de telefone: 5511999999999
#  - GRUPO (JID): 120363XXXXXXXXXXXXX@g.us  (descubra o JID em GET /api/whatsapp/grupos)
EVOLUTION_RECIPIENT=your-whatsapp-number

# AI Integration Providers
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
# Modelos (opcionais — defaults: gemini-2.5-flash / gpt-4o-mini). Trocar aqui
# não exige rebuild, só stack deploy (env é assada no spec do serviço).
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini

# API Security (rotas de IA)
# Token compartilhado exigido no header "Authorization: Bearer <API_TOKEN>" nas rotas de IA.
# Se ficar como o placeholder abaixo, as rotas são liberadas (apenas dev). Defina em produção.
API_TOKEN=your-api-token
# Origem do frontend para restringir o CORS (ex.: https://jotinhabet.eurekmind.com). Vazio = CORS aberto (dev).
FRONTEND_ORIGIN=

# Caminho do arquivo de cookies do SureRadar (no container: /app/sureradar.json montado via volume)
SURERADAR_COOKIES_PATH=/app/sureradar.json

# Telegram (GramJS/MTProto, sessão de USUÁRIO — bot não entra em grupo de terceiros)
# api_id/api_hash: crie um app em https://my.telegram.org/apps
# Sessão: npx ts-node --transpile-only src/scripts/telegram_login.ts (imprime a
# session string e a lista de grupos com seus IDs). Placeholder = fonte desligada.
TELEGRAM_API_ID=your-telegram-api-id
TELEGRAM_API_HASH=your-telegram-api-hash
TELEGRAM_SESSION=your-telegram-session-string
# ID(s) do(s) grupo(s) de sinais, separados por vírgula (supergrupos: -100xxxxxxxxxx).
# SEM comentário inline na mesma linha — o env_file do Swarm não remove!
TELEGRAM_GRUPO_ID=your-telegram-group-id
# Confiança mínima (0-100) da extração de visão para aceitar um sinal (default 70)
TELEGRAM_MIN_CONFIANCA=70
# Janela (segundos) após o sinal colhendo contexto do grupo — prints das casas
# (data/horário da partida) e links — antes de alertar (default 75)
TELEGRAM_CONTEXTO_SEGUNDOS=75
