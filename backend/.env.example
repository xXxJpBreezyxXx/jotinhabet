# Server Configuration
PORT=4000
NODE_ENV=development

# Supabase Database Configuration
# Use the direct postgres connection URI or the REST API credentials
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
# Conexão direta ao Postgres (usada pelas migrations em src/db/migrate.ts)
DATABASE_URL=postgresql://postgres:your-db-password@your-supabase-host:5432/postgres

# Security
# 32-byte encryption key (hex or base64) for Fernet/AES symmetric encryption of credentials
# Example generation command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# Notification API - Evolution API (WhatsApp)
EVOLUTION_API_URL=https://your-evolution-host/
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=your-instance-name
EVOLUTION_RECIPIENT=your-whatsapp-number

# AI Integration Providers
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# API Security (rotas de IA)
# Token compartilhado exigido no header "Authorization: Bearer <API_TOKEN>" nas rotas de IA.
# Se ficar como o placeholder abaixo, as rotas são liberadas (apenas dev). Defina em produção.
API_TOKEN=your-api-token
# Origem do frontend para restringir o CORS (ex.: https://jotinhabet.eurekmind.com). Vazio = CORS aberto (dev).
FRONTEND_ORIGIN=

# Caminho do arquivo de cookies do SureRadar (no container: /app/sureradar.json montado via volume)
SURERADAR_COOKIES_PATH=/app/sureradar.json
